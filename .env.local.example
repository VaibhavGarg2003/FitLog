# ════════════════════════════════════════════════════════════════
# FitLog — Environment Variables
# ════════════════════════════════════════════════════════════════
#
# HOW TO USE:
# 1. Copy this file: cp .env.local.example .env.local
# 2. Fill in your real values
# 3. NEVER commit .env.local to git (it's in .gitignore)
#
# TWO-ENVIRONMENT RULE (ADR-2):
#   .env.local       → the DEV Supabase project (laptop default)
#   .env.prod.local  → PROD database URLs ONLY (DATABASE_URL + DIRECT_URL),
#                      read exclusively by `npm run migrate:prod`
#   Vercel env vars  → PROD runtime (the deployed app never reads local files)
# The laptop points at dev by default; touching prod is a deliberate act.
#
# WHY .env.local?
# Next.js automatically reads .env.local and makes variables
# available via process.env.VARIABLE_NAME on the server side.
#
# Variables prefixed with NEXT_PUBLIC_ are also available in
# the browser. NEVER put secrets (API keys, DB passwords) in
# NEXT_PUBLIC_ variables — the browser JavaScript is visible
# to anyone who opens DevTools.
# ════════════════════════════════════════════════════════════════

# ─── Supabase ───────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# ANON KEY is safe to expose — it's rate-limited and RLS-protected.
# It can ONLY do what your RLS policies allow.

# ─── Database (Prisma) ─────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → Database → Connection string
DATABASE_URL=postgresql://postgres.your-project:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.your-project:password@aws-0-region.pooler.supabase.com:5432/postgres
# DATABASE_URL → pooled (port 6543) — for app queries
# DIRECT_URL  → direct (port 5432) — for prisma migrate only

# ─── Sentry ─────────────────────────────────────────────────
# Get from: https://sentry.io → Project Settings → Client Keys (DSN)
SENTRY_DSN=https://your-dsn@sentry.io/your-project-id
SENTRY_AUTH_TOKEN=your-sentry-auth-token
# DSN = Data Source Name. Tells Sentry SDK where to send error reports.

# ─── Upstash Redis ──────────────────────────────────────────
# Get from: https://console.upstash.com → Redis → your database
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# ─── LLM API Keys (server-side only — no NEXT_PUBLIC_) ─────
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key
OPENROUTER_API_KEY=your-openrouter-api-key

# ─── Google OAuth ───────────────────────────────────────────
# Configured in Supabase Dashboard → Authentication → Providers → Google
# You'll need a Google Cloud Console project with OAuth 2.0 credentials.

# ─── Vercel Cron Secret ─────────────────────────────────────
CRON_SECRET=generate-a-random-string-here
# When set, /api/health requires "Authorization: Bearer <this>".
# Leave empty to keep the health endpoint public (fine for keepalive pings).

# ─── USDA FoodData Central (seed only, not runtime) ─────────
# Free key from https://api.data.gov/signup/
USDA_API_KEY=your-usda-api-key
